# ══════════════════════════════════════════════════════════════════
# MITRE ATT&CK Threat Analyzer — Environment Variables Template
# Copy to .env.local and fill in your values (never commit .env.local)
# ══════════════════════════════════════════════════════════════════

# ── Azure OpenAI / AI Foundry (required for AI threat analysis) ────
# Endpoint: find in Azure OpenAI Studio → your deployment → "Endpoint"
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# Deployment name: the model deployment you created (e.g. "gpt-4o")
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# API Key: used for local dev only; production uses Managed Identity
AZURE_OPENAI_API_KEY=

# ── Database ───────────────────────────────────────────────────────
# Local dev   → SQLite (no setup required, leave as-is)
# Production  → Azure SQL (constructed automatically by deploy.sh)
DATABASE_URL=sqlite:///./data/mitre.db

# ── Azure SQL credentials (required only for Azure deployment) ─────
# These are used by setup.sh and deploy.sh to create/connect to Azure SQL.
SQL_ADMIN_LOGIN=sqladmin
SQL_ADMIN_PASSWORD=your-strong-password-here

# ── STIX data cache ────────────────────────────────────────────────
STIX_DATA_DIR=./data/stix

# ── MITRE sync ────────────────────────────────────────────────────
SYNC_INTERVAL_HOURS=24

# ── Application ───────────────────────────────────────────────────
# Set to false in production
DEBUG=true

# ── CORS ──────────────────────────────────────────────────────────
# Local dev: leave as-is
# Production: set to your Azure Container App URL (set automatically by deploy.sh)
FRONTEND_URL=http://localhost:5173
